{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./target/generated-sources/openapi/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "target/generated-sources/openapi/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
