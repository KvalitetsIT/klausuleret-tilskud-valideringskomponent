<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Tekst ud i konsollen med pæne multiline stack traces (super nice) -->
    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n%ex{full}</pattern>
        </encoder>
    </appender>

    <logger name="dk.kvalitetsit" level="${LOG_LEVEL:-INFO}" additivity="false">
        <appender-ref ref="CONSOLE_TEXT"/>
    </logger>

    <root level="${LOG_LEVEL_FRAMEWORK:-INFO}">
        <appender-ref ref="CONSOLE_TEXT"/>
    </root>
</configuration>
